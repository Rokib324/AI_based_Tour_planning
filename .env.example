# ── Django ─────────────────────────────
SECRET_KEY=your-secret-key-here
DEBUG=True

# ── Email (Gmail SMTP) ─────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=TravelAI <your-gmail@gmail.com>

# ── Google OAuth (Sign in with Google) ─
# Create credentials at https://console.cloud.google.com/apis/credentials
# Application type: Web application
# Authorized JavaScript origins: http://127.0.0.1:8000
# Authorized redirect URIs: not required for GIS One Tap / button flow
GOOGLE_CLIENT_ID=your-google-oauth2-client-id.apps.googleusercontent.com

# ── Facebook OAuth ─────────────────────
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# ── Twilio (Phone OTP / SMS) ───────────
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ── Frontend Base URL ──────────────────
FRONTEND_BASE_URL=http://127.0.0.1:8000
